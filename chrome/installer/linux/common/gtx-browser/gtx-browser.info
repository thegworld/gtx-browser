# This file provides common configuration information for building
# chromium-browser packages for various platforms.

# Base name of the package.
PACKAGE="gtx-browser"

# Base name of the snap package
SNAPNAME="gtxbrowser"

# Filename of the main executable (for generating launcher scripts, etc.)
PROGNAME=gtxbrowser

# Base directory for package installation.
INSTALLDIR=/opt/gtx.io/gtx-browser

# Directory for device policy enrollments.
ENROLLMENTDIR=/etc/gtx-browser/policies/enrollment

# Display string for desktop menu/icon.
MENUNAME="GTx Browser"

# Brief package description.
SHORTDESC="The web browser from GTx.io"

# Detailed package description.
FULLDESC="GTx Browse is a browser that combines a minimal design with sophisticated technology to make web3 faster, safer, and easier."

# Package maintainer information.
# TODO(mmoss) Setup a mailbox for this address
MAINTNAME="GTx Browser Team"
MAINTMAIL="gtx-browser-packager@gtx.io"
PRODUCTURL="https://gtx.io/"
