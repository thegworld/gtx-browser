<translation id="1131805035311359397">Şifrelerinizin veri ihlali ve diğer güvenlik sorunlarına karşı güvende olup olmadığını kontrol etmek için <ph name="BEGIN_LINK" />GTx Browser'da oturum açın<ph name="END_LINK" />.</translation>
<translation id="1157106475430165622">{NUM_DEVICES,plural, =0{GTx Browser uzantıları, HID cihazlarına erişiyordu}=1{GTx Browser uzantıları, HID cihazlarına erişiyor}other{GTx Browser uzantıları, # HID cihazına erişiyor}}</translation>
